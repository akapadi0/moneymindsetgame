{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist/public",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin-allow-popups" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/server" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}

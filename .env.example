# ============================================================
# WealthIQ Money Mindset Assessment — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.
# ============================================================

# PostgreSQL connection string (required)
# For Vercel, use a hosted provider like Neon (neon.tech) or Supabase.
# Example (Neon): postgres://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=postgres://user:password@host:5432/dbname

# Outlook / Microsoft 365 SMTP credentials (required for email)
# Used to send results emails via smtp.office365.com:587
OUTLOOK_USER=hello@wealthiqco.com
OUTLOOK_PASS=your-outlook-app-password

# Admin API key (required to access GET /api/submissions)
# Choose any long, random string. Pass it as the x-admin-key header.
# Example: openssl rand -hex 32
ADMIN_API_KEY=replace-with-a-long-random-secret

# Optional: override the port for local development (default: 5000)
# PORT=5000
